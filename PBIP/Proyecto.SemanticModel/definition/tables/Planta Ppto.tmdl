	measure 'Total-Sena YTD Año Seleccionado' =
			
			VAR AnioSel = SELECTEDVALUE('DimPeriodoYM'[Año])
			VAR MesMax = MAX('DimPeriodoYM'[Numero])
			RETURN
			IF(
			    OR(ISBLANK(AnioSel), ISBLANK(MesMax)),
			    BLANK(),
			    CALCULATE(
			        [SumadeTotal-Sena],
			        'DimPeriodoYM'[Año] = AnioSel,
			        FILTER(ALL('DimPeriodoYM'[Numero]), 'DimPeriodoYM'[Numero] <= MesMax)
			    )
			)
		formatString: 0
		displayFolder: Medidas
		lineageTag: 0c692bb4-192f-44d8-980e-8f4f516bb564

