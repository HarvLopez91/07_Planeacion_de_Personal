	measure Resumen = SUM('Planta Ppto'[Total])
		formatString: 0
		displayFolder: Medidas
		lineageTag: 4cd9619f-5262-441f-8f78-8c1cce817be9

		changedProperty = IsHidden

	measure tot_Año_prom =
			
			VAR MesSel = MAX ( 'Planta Ppto'[Mes Num] )
			RETURN
			DIVIDE(
			    CALCULATE(
			        [Resumen],
			        FILTER(
			            ALL ( 'Planta Ppto'[Mes Num] ),
			            'Planta Ppto'[Mes Num] <= MesSel
			        )
			    ),
			    CALCULATE(
			        DISTINCTCOUNT ( 'Planta Ppto'[Mes Num] ),
			        FILTER(
			            ALL ( 'Planta Ppto'[Mes Num] ),
			            'Planta Ppto'[Mes Num] <= MesSel
			        )
			    )
			)
		formatString: #,0.00
		displayFolder: Medidas
		lineageTag: 5f68c1c5-9b09-4ea7-ae36-ac0712edba0c

		changedProperty = IsHidden

	measure Var_Ppto =
			
			VAR Ppto2025 =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Ppto",
			        'Planta Ppto'[Año] = "2025"
			    )
			VAR Ppto2024 =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Ppto",
			        'Planta Ppto'[Año] = "2024"
			    )
			RETURN
			DIVIDE( Ppto2025, Ppto2024 ) - 1
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: Medidas
		lineageTag: eb629bb9-c65d-42b3-ad0f-b3f59547e6b4

		changedProperty = IsHidden

	measure Var_Real =
			( CALCULATE([tot_Año_prom],'Planta Ppto'[Ppto/Real]="Real",'Planta Ppto'[Año]="2025")/
			CALCULATE([tot_Año_prom],'Planta Ppto'[Ppto/Real]="Real",'Planta Ppto'[Año]="2024"))-1
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: Medidas
		lineageTag: c87924ea-9a2d-40d9-acd1-3f11a6210689

		changedProperty = IsHidden

