	measure tot_Año_Indef_PromEmpresas_FIX =
			
			VAR MesSel = MAX ( 'Planta Ppto'[Mes Num] )
			
			-- Promedio YTD consolidado (suma de empresas seleccionadas / #meses YTD)
			VAR NumYTD_Total =
			    CALCULATE(
			        [Tot_Indef],
			        FILTER( ALL('Planta Ppto'[Mes Num]), 'Planta Ppto'[Mes Num] <= MesSel )
			    )
			
			VAR DenYTD_Total =
			    CALCULATE(
			        DISTINCTCOUNT('Planta Ppto'[Mes Num]),
			        FILTER( ALL('Planta Ppto'[Mes Num]), 'Planta Ppto'[Mes Num] <= MesSel )
			    )
			
			VAR PromYTD_Total = DIVIDE( NumYTD_Total, DenYTD_Total )
			
			-- Promedio YTD por empresa (para cuando estás en el nivel Empresa)
			VAR PromYTD_PorEmpresa =
			    AVERAGEX(
			        VALUES ( 'Planta Ppto'[Empresa] ),
			        VAR NumYTD_Emp =
			            CALCULATE(
			                [Tot_Indef],
			                FILTER( ALL('Planta Ppto'[Mes Num]), 'Planta Ppto'[Mes Num] <= MesSel )
			            )
			        VAR DenYTD_Emp =
			            CALCULATE(
			                DISTINCTCOUNT('Planta Ppto'[Mes Num]),
			                FILTER( ALL('Planta Ppto'[Mes Num]), 'Planta Ppto'[Mes Num] <= MesSel )
			            )
			        RETURN DIVIDE( NumYTD_Emp, DenYTD_Emp )
			    )
			
			RETURN
			IF(
			    ISINSCOPE('Planta Ppto'[Empresa]),   -- Si estoy en fila Empresa
			    PromYTD_PorEmpresa,                  -- muestro promedio por empresa
			    PromYTD_Total                        -- si es total, muestro consolidado
			)
		displayFolder: Medidas
		lineageTag: df1e2e0b-fc91-493e-a82f-989ef99867ed

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure tot_Año_Fijo_PromEmpresas_FIX = ```
			
