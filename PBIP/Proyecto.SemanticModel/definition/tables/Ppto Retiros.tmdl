	column 'Detalle (grupos)' =
			SWITCH(
				TRUE,
				ISBLANK('Ppto Retiros'[Detalle]),
				"(En blanco)",
				'Ppto Retiros'[Detalle] IN {"Abandono Puesto de Trabajo",
					"RENUNCIA TACITA"},
				"Abandono Puesto de Trabajo",
				'Ppto Retiros'[Detalle] IN {"CESION CONTRATO",
					"CESION DE CONTRATO"},
				"Cesión de Contrato",
				'Ppto Retiros'[Detalle] IN {"FALLECIMIENTO"},
				"Fallecimiento",
				'Ppto Retiros'[Detalle] IN {"FIN DE OBRA O LABOR/DEFINITIVO",
					"FIN DE OBRA O LABOR/DEFITIVO",
					"FIN DE OBRA/DEFINITIVO",
					"Fin Obra o Labor Definitivo",
					"FINDE OBRA O LABOR/DEFITIVO",
					"VENCIMIENTO  DE CONTRATO/DEFINITIVO",
					"VENCIMIENTO CONTRATO / DEFINITIVO",
					"VENCIMIENTO CONTRATO/DEFINITIVO",
					"VENCIMIENTO DE CONTRATO/DEFINITIVO"},
				"Fin Obra o Labor Definitivo",
				'Ppto Retiros'[Detalle] IN {"PENSION POR INVALIDEZ",
					"Pensión por Invalidez"},
				"Pensión por Invalidez",
				'Ppto Retiros'[Detalle] IN {"PERIODO DE PRUEBA"},
				"Periodo de Prueba",
				'Ppto Retiros'[Detalle] IN {"Terminación con Justa Causa",
					"TERMINACION CONTRATO CON JUSTA CAUSA",
					"TERMINACION DE CONTRATO CON JUSTA CAUSA"},
				"Terminación con Justa Causa",
				'Ppto Retiros'[Detalle] IN {"TERMINACION CONTRATO / DEFINITIVO",
					"Terminación Contrato Definitivo"},
				"Terminación Contrato Definitivo",
				'Ppto Retiros'[Detalle] IN {"MUTUO ACUERDO",
					"MUTUO ACUERDO DEFINITIVO",
					"Terminación de Contrato por Mutuo Acuerdo"},
				"Terminación de Contrato por Mutuo Acuerdo",
				'Ppto Retiros'[Detalle] IN {"TERMINACION CONTRATO SIN JUSTA CAUSA",
					"TERMINACION DE CONTRATO SIN JUSTA CAUSA",
					"Terminación sin Justa Causa",
					"TERMINACION UNILATERAL SIN JUSTA CAUSA"},
				"Terminación sin Justa Causa",
				'Ppto Retiros'[Detalle]
			)
		lineageTag: 0ca82e43-e8e4-44d9-8f08-30e13a002825
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "Ppto Retiros"
				          }
				        },
				        "Property": "Detalle"
				      }
				    }
				  ]
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"p","Entity":"Ppto Retiros"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"GroupItems":[{"DisplayName":"(En blanco)","BlankDefaultPlaceholder":true},{"DisplayName":"Abandono Puesto de Trabajo","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"Values":[[{"Literal":{"Value":"'Abandono Puesto de Trabajo'"}}],[{"Literal":{"Value":"'RENUNCIA TACITA'"}}]]}}},{"DisplayName":"Cesión de Contrato","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"Values":[[{"Literal":{"Value":"'CESION CONTRATO'"}}],[{"Literal":{"Value":"'CESION DE CONTRATO'"}}]]}}},{"DisplayName":"Fallecimiento","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"Values":[[{"Literal":{"Value":"'FALLECIMIENTO'"}}]]}}},{"DisplayName":"Fin Obra o Labor Definitivo","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"Values":[[{"Literal":{"Value":"'FIN DE OBRA O LABOR/DEFINITIVO'"}}],[{"Literal":{"Value":"'FIN DE OBRA O LABOR/DEFITIVO'"}}],[{"Literal":{"Value":"'FIN DE OBRA/DEFINITIVO'"}}],[{"Literal":{"Value":"'Fin Obra o Labor Definitivo'"}}],[{"Literal":{"Value":"'FINDE OBRA O LABOR/DEFITIVO'"}}],[{"Literal":{"Value":"'VENCIMIENTO  DE CONTRATO/DEFINITIVO'"}}],[{"Literal":{"Value":"'VENCIMIENTO CONTRATO / DEFINITIVO'"}}],[{"Literal":{"Value":"'VENCIMIENTO CONTRATO/DEFINITIVO'"}}],[{"Literal":{"Value":"'VENCIMIENTO DE CONTRATO/DEFINITIVO'"}}]]}}},{"DisplayName":"Pensión por Invalidez","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"Detalle"}}],"Values":[[{"Literal":{"Value":"'PENSION POR INVALIDEZ'"}}],[{"Literal":{"Value":"'Pensión por Invalidez'"}}]]}}},{"DisplayName":"Periodo de Prueba","Expression":