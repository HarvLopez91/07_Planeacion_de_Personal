	column 'Tipo de retiro' =
			VAR _m = UPPER ( TRIM ( 'Ppto Retiros'[Detalle] ) )
			RETURN
			IF (
			    _m IN {
			        "ABANDONO PUESTO DE TRABAJO",
			        "RENUNCIA TACITA",
			        "RENUNCIA VOLUNTARIA"
			    },
			    "Voluntario",
			    IF ( _m = "", "Sin clasificar", "Involuntario" )
			)
		dataType: string
		lineageTag: d64ab5ff-5a59-4b44-8971-ebd0af2cce8e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

