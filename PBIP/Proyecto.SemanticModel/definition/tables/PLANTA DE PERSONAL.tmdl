				            "Entity": "PLANTA DE PERSONAL"
				          }
				        },
				        "Property": "TIPO_CONTR"
				      }
				    }
				  ]
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"p","Entity":"PLANTA DE PERSONAL"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"TIPO_CONTR"}}],"GroupItems":[{"DisplayName":"(En blanco)","BlankDefaultPlaceholder":true},{"DisplayName":"Contrato De Aprendizaje","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"TIPO_CONTR"}}],"Values":[[{"Literal":{"Value":"'Contrato Aprendizaje'"}}],[{"Literal":{"Value":"'Contrato De Aprendizaje'"}}],[{"Literal":{"Value":"'Sena'"}}]]}}},{"DisplayName":"Contrato Fijo","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"TIPO_CONTR"}}],"Values":[[{"Literal":{"Value":"'Contrato Fijo'"}}],[{"Literal":{"Value":"'Fijo'"}}]]}}},{"DisplayName":"Contrato Indefinido","Expression":{"In":{"Expressions":[{"Column":{"Expression":{"SourceRef":{"Source":"p"}},"Property":"TIPO_CONTR"}}],"Values":[[{"Literal":{"Value":"'Contrato Indefinido'"}}],[{"Literal":{"Value":"'Indefinido'"}}]]}}}]}

