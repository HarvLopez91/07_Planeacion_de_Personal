table 'PLANTA DE PERSONAL'
	lineageTag: 94e6a784-2a65-40b7-9821-0590a4c7873c

	measure Tot_empleados = COUNT('PLANTA DE PERSONAL'[ID])
		formatString: #,0
		displayFolder: Medidas
		lineageTag: 05f1012d-4a54-4484-b749-cd4547868ad5

	measure Tot_Fem = CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[SEXO]="FEMENINO")
		formatString: #,0
		displayFolder: Medidas
		lineageTag: 8bf4cf9f-57e6-4174-b7b6-28a44e5a4946

	measure Tot_Mas = CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[SEXO]="MASCULINO")
		formatString: #,0
		displayFolder: Medidas
		lineageTag: e6f59180-5de8-41c4-af58-9dff5efd321f

	measure %FEM = [Tot_Fem]/[Tot_empleados]
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: Medidas
		lineageTag: f2c0e2fa-4f4d-478e-85ea-40036892cc9f

	measure %MASC = [Tot_Mas]/[Tot_empleados]
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: Medidas
		lineageTag: 8c75d7cc-e951-4d43-8208-df49037ba3ea

	measure Prom_Colaboradores = (CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="01.Enero")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="02.Febrero")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="03.Marzo")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="04.Abril")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="05.Mayo")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="06.Junio")+CALCULATE([Tot_empleados],'PLANTA DE PERSONAL'[MES]="07.Julio"))/7
		formatString: 0
		displayFolder: Medidas
		lineageTag: eb863c24-1dd7-4be6-8d59-c383be197778

	measure Tot_Colab-Sena = CALCULATE(COUNT('PLANTA DE PERSONAL'[ID]),'PLANTA DE PERSONAL'[TIPO_CONTR]<>"CONTRATO APRENDIZAJE")
		formatString: #,0
		displayFolder: Medidas
		lineageTag: 2ae49392-771e-430f-b059-cbecdf65b571

	measure orden
		lineageTag: c642fb03-a4c6-430e-b946-4ab950a1d9c4

	measure Tot_Colab-Directos = CALCULATE(COUNT('PLANTA DE PERSONAL'[ID]),'PLANTA DE PERSONAL'[TIPO_CONTR]="CONTRATO FIJO")+CALCULATE(COUNT('PLANTA DE PERSONAL'[ID]),'PLANTA DE PERSONAL'[TIPO_CONTR]="CONTRATO INDEFINIDO")
		formatString: #,0
		displayFolder: Medidas
		lineageTag: 834eafb9-1b26-421d-90ac-707ccff9a8d4

	measure Tot_empleados_Promedio =
			
			AVERAGEX(
			    VALUES('PLANTA DE PERSONAL'[Mes]),
			    CALCULATE( COUNT('PLANTA DE PERSONAL'[ID]) )
			)
		displayFolder: Medidas
		lineageTag: 21a53e63-c392-4f68-aeff-f3eb941e720c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

