	column 'TIPO_CONTR (grupos)' =
			SWITCH(
				TRUE,
				ISBLANK('PLANTA DE PERSONAL'[TIPO_CONTR]),
				"(En blanco)",
				'PLANTA DE PERSONAL'[TIPO_CONTR] IN {"Contrato Aprendizaje",
					"Contrato De Aprendizaje",
					"Sena"},
				"Contrato De Aprendizaje",
				'PLANTA DE PERSONAL'[TIPO_CONTR] IN {"Contrato Fijo",
					"Fijo"},
				"Contrato Fijo",
				'PLANTA DE PERSONAL'[TIPO_CONTR] IN {"Contrato Indefinido",
					"Indefinido"},
				"Contrato Indefinido",
				'PLANTA DE PERSONAL'[TIPO_CONTR]
			)
		lineageTag: a3c08878-5b75-4131-8ed6-0049c2d57717
		summarizeBy: none

