	column 'EST_CIVIL (grupos)' =
			SWITCH(
				TRUE,
				ISBLANK('PLANTA DE PERSONAL'[EST_CIVIL]),
				"(En blanco)",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"C",
					"Casado"},
				"Casado",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"D",
					"Divorciado"},
				"Divorciado",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"N/R",
					"O",
					"Otro"},
				"Otro",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"S",
					"Soltero"},
				"Soltero",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"U",
					"Unión Libre"},
				"Unión Libre",
				'PLANTA DE PERSONAL'[EST_CIVIL] IN {"V",
