	measure Retiros_Segun_Tipo =
			VAR TipoSeleccionado = SELECTEDVALUE ( 'Ppto Retiros'[Tipo de retiro], "Total" )
			RETURN
			SWITCH (
			    TipoSeleccionado,
			    "Voluntario", [Cantidad_Retiros_Voluntarios],
			    "Involuntario", [Cantidad_Retiros_Involuntarios],
			    [Cantidad_Retiros]
			)
		formatString: 0
		displayFolder: 03 Ingresos y Retiros
		lineageTag: f1a2b3c4-d5e6-7f8a-9b0c-d1e2f3a4b5c6

	measure Rotacion_Segun_Tipo =
			VAR TipoSeleccionado = SELECTEDVALUE ( 'Ppto Retiros'[Tipo de retiro], "Total" )
			RETURN
			SWITCH (
			    TipoSeleccionado,
			    "Voluntario", [Rotacion_Voluntaria_Anual_Acumulada],
			    "Involuntario", [Rotacion_Involuntaria_Anual_Acumulada],
			    [Rotacion_Anual_Acumulada]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: 03 Ingresos y Retiros
		lineageTag: e2d3c4b5-a6f7-8e9d-0c1b-2a3f4e5d6c7b

	measure GL_Ppto_Gasto_Personal = SUM('Planta Ppto'[Ppto Gasto Personal])
		displayFolder: 02 Ppto vs Real
		lineageTag: 5bada4f2-ceeb-40bc-aaee-c403c2650c03

		formatStringDefinition =
				VAR Valor = ABS ( [GL_Ppto_Gasto_Personal] )
				RETURN
				IF (
				    [GL_Usar_Millones],
				    "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				    SWITCH (
				        TRUE (),
				        Valor >= 1000000000, "$ #,0,,,.0 ""bill."";-$ #,0,,,.0 ""bill."";$ 0.0 ""bill.""",
				        Valor >= 1000000, "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				        Valor >= 1000, "$ #,0,.0 ""mil"";-$ #,0,.0 ""mil"";$ 0.0 ""mil""",
				        "$ #,0.0;-$ #,0.0;$ 0.0"
				    )
				)

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

	measure GL_Gasto_Personal = SUM('Planta Ppto'[Gasto Personal])
		displayFolder: 02 Ppto vs Real
		lineageTag: e220c2b3-1481-4bff-871c-53ee705a9d67

		formatStringDefinition =
				VAR Valor = ABS ( [GL_Gasto_Personal] )
				RETURN
				IF (
				    [GL_Usar_Millones],
				    "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				    SWITCH (
				        TRUE (),
				        Valor >= 1000000000, "$ #,0,,,.0 ""bill."";-$ #,0,,,.0 ""bill."";$ 0.0 ""bill.""",
				        Valor >= 1000000, "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				        Valor >= 1000, "$ #,0,.0 ""mil"";-$ #,0,.0 ""mil"";$ 0.0 ""mil""",
				        "$ #,0.0;-$ #,0.0;$ 0.0"
				    )
				)

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

	measure GL_Usar_Millones =
			VAR HayFiltroGrupo =
			    ISFILTERED ( Empresas[Grupo Empresa] )
			VAR HayFiltroEmpresa =
			    ISFILTERED ( Empresas[Empresas] )
			VAR GruposSeleccionados =
			    FILTER (
			        ALLSELECTED ( Empresas[Grupo Empresa] ),
			        NOT ISBLANK ( Empresas[Grupo Empresa] )
			    )
			VAR GruposVisibles =
			    COUNTROWS ( GruposSeleccionados )
			VAR TotalGrupos =
			    CALCULATE (
			        DISTINCTCOUNT ( Empresas[Grupo Empresa] ),
			        REMOVEFILTERS ( Empresas )
			    )
			VAR GrupoUnico =
			    SELECTEDVALUE ( Empresas[Grupo Empresa] )
			VAR EsChallengerEfectivo =
			    GruposVisibles = 1
			        && GrupoUnico = "Challenger"
			VAR SinFiltroNegocio =
			    NOT HayFiltroGrupo && NOT HayFiltroEmpresa
			VAR EstanTodosLosGrupos =
			    GruposVisibles = TotalGrupos
			RETURN
			    EsChallengerEfectivo || SinFiltroNegocio || EstanTodosLosGrupos
		displayFolder: 02 Ppto vs Real
		lineageTag: fe4d54d4-22ed-411b-b776-383d87903635

		changedProperty = IsHidden

	measure GL_Ppto_Visual_Challenger = IF ( [GL_Usar_Millones], [GL_Ppto_Gasto_Personal], BLANK() )
		formatString: \$\ #,0.###############;-\$\ #,0.###############;\$\ #,0.###############
		displayFolder: 02 Ppto vs Real
		lineageTag: 16fafe11-2224-46f5-931c-f48a67abbaa7

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

