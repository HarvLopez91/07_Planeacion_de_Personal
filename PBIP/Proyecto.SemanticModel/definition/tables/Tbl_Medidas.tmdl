	measure Tot_Sena = SUM('Planta Ppto'[Sena])
		formatString: 0
		displayFolder: 02 Ppto vs Real
		lineageTag: 3abfcbdc-0417-41b3-90c7-fabd7b8f9d5e

		changedProperty = IsHidden

	measure tot_Año_Sena_prom =
			
			VAR MesSel = MAX ( 'Planta Ppto'[Mes Num] )
			RETURN
			DIVIDE(
			    CALCULATE(
			        [Tot_Sena],
			        FILTER(
