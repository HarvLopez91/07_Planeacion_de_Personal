	measure Rotacion_Involuntaria =
			DIVIDE (
			    [Retiros_Involuntarios],
			    [PromediodeTotal-Sena],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: 03 Ingresos y Retiros
