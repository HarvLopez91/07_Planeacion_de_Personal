	measure AnioActual_Comparado =
			
			VAR AniosSel = VALUES ( 'Años'[Año] )
			VAR NumAnios = COUNTROWS ( AniosSel )
			RETURN
			IF (
			    NumAnios >= 1 && NumAnios <= 2,
			    MAXX ( AniosSel, VALUE ( 'Años'[Año] ) ),
			    CALCULATE ( MAXX ( 'Años', VALUE ( 'Años'[Año] ) ), ALL ( 'Años' ) )
			)
		formatString: 0
		displayFolder: 02 Ppto vs Real
		lineageTag: e6f2ba63-715a-4f23-b975-7c5e0f56abb8

		changedProperty = IsHidden

	measure AnioAnterior_Comparado =
			
			VAR AniosSel = VALUES ( 'Años'[Año] )
			VAR NumAnios = COUNTROWS ( AniosSel )
			RETURN
			IF (
			    NumAnios = 2,
			    MINX ( AniosSel, VALUE ( 'Años'[Año] ) ),
			    [AnioActual_Comparado] - 1
			)
		formatString: 0
		displayFolder: 02 Ppto vs Real
		lineageTag: e20c7118-3e6d-4b1c-a7a8-a39ba78c98c4

		changedProperty = IsHidden

	measure Titulo_Var_Ppto =
			
			VAR AnioAct = [AnioActual_Comparado]
			VAR AnioAnt = [AnioAnterior_Comparado]
			RETURN
			IF(
			    ISBLANK ( AnioAct ) || ISBLANK ( AnioAnt ),
			    "Variación Presupuesto (sin año disponible)",
			    "Variación Presupuesto (" & AnioAct & " vs. " & AnioAnt & ")"
			)
		displayFolder: 02 Ppto vs Real
		lineageTag: 34af358c-ca90-4cf4-84cf-70963c5ce67b

	measure Titulo_Var_Real =
			
			VAR AnioAct = [AnioActual_Comparado]
			VAR AnioAnt = [AnioAnterior_Comparado]
			RETURN
			IF(
			    ISBLANK ( AnioAct ) || ISBLANK ( AnioAnt ),
			    "Variación Real (sin año disponible)",
			    "Variación Real (" & AnioAct & " vs. " & AnioAnt & ")"
			)
		displayFolder: 02 Ppto vs Real
		lineageTag: 59db7ea4-726b-43e5-93ef-5f09f5ce19bb

	measure Titulo_Productividad_Gasto_Laboral =

			VAR AnioSeleccionado =
			    SELECTEDVALUE ( 'Años'[Año] )
			RETURN
			    "Gasto Laboral Vs Ventas - Ejecución "
			        & IF (
			            NOT ISBLANK ( AnioSeleccionado ),
			            AnioSeleccionado,
			            "años seleccionados"
			        )
		displayFolder: 02 Ppto vs Real
		lineageTag: 8f0a00d7-a72b-4cda-8f0c-bd57ec44f9e4

