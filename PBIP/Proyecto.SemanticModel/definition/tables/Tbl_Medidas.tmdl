		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 05 Productividad
		lineageTag: 244a94d2-b146-419e-97cf-e00c8a69ace3

		changedProperty = IsHidden

	measure Prod_Gasto_Personal_Otros =

			IF ( NOT [Prod_Usar_Millones], [Prod_Gasto_Personal], BLANK() )
		displayFolder: 05 Productividad
		lineageTag: b74db4eb-2c14-4fa6-9cb8-74ea282d52eb

		formatStringDefinition =
				VAR Valor = ABS ( [Prod_Gasto_Personal] )
				RETURN
				SWITCH (
				    TRUE (),
				    Valor >= 1000000000, "$ #,0,,,.0 ""bill."";-$ #,0,,,.0 ""bill."";$ 0.0 ""bill.""",
				    Valor >= 1000000, "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				    Valor >= 1000, "$ #,0,.0 ""mil"";-$ #,0,.0 ""mil"";$ 0.0 ""mil""",
				    "$ #,0.0;-$ #,0.0;$ 0.0"
				)

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

	measure Prod_Ingreso_Operacional_Otros =

			IF ( NOT [Prod_Usar_Millones], [Prod_Ingreso_Operacional], BLANK() )
		displayFolder: 05 Productividad
		lineageTag: 8579edff-3f66-4bdb-a9e7-bb4729a17d2f

		formatStringDefinition =
				VAR Valor = ABS ( [Prod_Ingreso_Operacional] )
				RETURN
				SWITCH (
				    TRUE (),
				    Valor >= 1000000000, "$ #,0,,,.0 ""bill."";-$ #,0,,,.0 ""bill."";$ 0.0 ""bill.""",
				    Valor >= 1000000, "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill.""",
				    Valor >= 1000, "$ #,0,.0 ""mil"";-$ #,0,.0 ""mil"";$ 0.0 ""mil""",
