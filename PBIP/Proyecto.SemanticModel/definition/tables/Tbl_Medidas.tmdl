table Tbl_Medidas
	lineageTag: bf0f5853-c510-4e8d-8ba2-4352941e31be

	measure 'Filtro Trimestre Slicer' =
			
			VAR PeriodoSel =
			    SELECTEDVALUE ( DimPeriodoYM[Trimestre anterior])
			VAR FlagActual =
			    MAX ( DimPeriodoYM[EsTrimActual] )      -- 0 ó 1
			VAR FlagAnterior =
			    MAX ( DimPeriodoYM[EsTrimAnterior] )    -- 0 ó 1
			RETURN
			SWITCH (
			    TRUE (),
			    PeriodoSel = "Trimestre actual",   FlagActual,
			    PeriodoSel = "Trimestre anterior", FlagAnterior,
			    1   -- si no hay nada seleccionado, no filtra
			)
		formatString: 0
		displayFolder: 00 Utilidades
		lineageTag: dc1af8d7-cda5-4ba6-a898-40ded687c8a6

	measure Cantidad_Retiros = SUM('Planta Ppto'[Retiros])
		formatString: 0
		displayFolder: 03 Ingresos y Retiros
		lineageTag: bb62b9dd-c0c5-4a90-8442-4cd341dc6035

	measure Rotacion_Anual_Acumulada =
			
			DIVIDE (
			    [Cantidad_Retiros],
			    [PromediodeTotal-Sena],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: 03 Ingresos y Retiros
		lineageTag: 8d79992a-eb85-4e9f-a0e6-dfd3d639cd62

	measure Tot_empleados = COUNT('PLANTA DE PERSONAL'[ID])
