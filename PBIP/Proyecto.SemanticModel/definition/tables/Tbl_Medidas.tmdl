		formatStringDefinition = "$ #,0,,.0 ""mill."";-$ #,0,,.0 ""mill."";$ 0.0 ""mill."""

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

