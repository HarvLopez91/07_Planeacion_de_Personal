	measure Retiros_Voluntarios =
			CALCULATE (
			    [Tot_Retiros],
			    KEEPFILTERS ( 'Ppto Retiros'[Tipo de retiro] = "Voluntario" )
			)
		formatString: #,0
		displayFolder: 03 Ingresos y Retiros
		lineageTag: 4c5855f7-f2c5-40b5-8c38-ae9593d3805f

	measure Retiros_Involuntarios =
			CALCULATE (
			    [Tot_Retiros],
			    KEEPFILTERS ( 'Ppto Retiros'[Tipo de retiro] = "Involuntario" )
			)
		formatString: #,0
		displayFolder: 03 Ingresos y Retiros
		lineageTag: 17ec4f45-276c-45f6-ba0a-cee3d2086507

	measure Participacion_Retiros_Voluntarios =
			DIVIDE (
			    [Retiros_Voluntarios],
			    [Tot_Retiros],
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: 03 Ingresos y Retiros
		lineageTag: 760b2503-5294-4100-acbe-20b0f7f3df36

	measure Rotacion_Voluntaria =
			DIVIDE (
