	measure Ind_Rot = (SUM('Planta Ppto'[Ingresos])-SUM('Planta Ppto'[Retiros]))/sum('Planta Ppto'[Total-Sena])
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: 02 Ppto vs Real
		lineageTag: 19650ba2-b55d-4486-b176-fac7bc1c9a97

		changedProperty = IsHidden

	measure Resumen = SUM('Planta Ppto'[Total])
		formatString: 0
		displayFolder: 02 Ppto vs Real
		lineageTag: 4cd9619f-5262-441f-8f78-8c1cce817be9

		changedProperty = IsHidden

	measure tot_Año_prom =
			
			VAR MesSel = MAX ( 'Planta Ppto'[Mes Num] )
			RETURN
			DIVIDE(
			    CALCULATE(
			        [Resumen],
			        FILTER(
			            ALL ( 'Planta Ppto'[Mes Num] ),
			            'Planta Ppto'[Mes Num] <= MesSel
			        )
			    ),
			    CALCULATE(
			        DISTINCTCOUNT ( 'Planta Ppto'[Mes Num] ),
			        FILTER(
			            ALL ( 'Planta Ppto'[Mes Num] ),
			            'Planta Ppto'[Mes Num] <= MesSel
			        )
			    )
			)
		formatString: #,0.00
		displayFolder: 02 Ppto vs Real
		lineageTag: 5f68c1c5-9b09-4ea7-ae36-ac0712edba0c

		changedProperty = IsHidden

	measure Var_Ppto =
			
			VAR AnioAct = FORMAT ( [AnioActual_Comparado], "0" )
			VAR AnioAnt = FORMAT ( [AnioAnterior_Comparado], "0" )
			VAR PptoActual =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Ppto",
			        'Planta Ppto'[Año] = AnioAct
			    )
			VAR PptoAnterior =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Ppto",
			        'Planta Ppto'[Año] = AnioAnt
			    )
			VAR Ratio = DIVIDE ( PptoActual, PptoAnterior )
			RETURN
			IF ( ISBLANK ( Ratio ), BLANK(), Ratio - 1 )
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: 02 Ppto vs Real
		lineageTag: eb629bb9-c65d-42b3-ad0f-b3f59547e6b4

		changedProperty = IsHidden

	measure Var_Real =
			
			VAR AnioAct = FORMAT ( [AnioActual_Comparado], "0" )
			VAR AnioAnt = FORMAT ( [AnioAnterior_Comparado], "0" )
			VAR RealActual =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Real",
			        'Planta Ppto'[Año] = AnioAct
			    )
			VAR RealAnterior =
			    CALCULATE(
			        [tot_Año_prom],
			        'Planta Ppto'[Ppto/Real] = "Real",
			        'Planta Ppto'[Año] = AnioAnt
			    )
			VAR Ratio = DIVIDE ( RealActual, RealAnterior )
			RETURN
			IF ( ISBLANK ( Ratio ), BLANK(), Ratio - 1 )
		formatString: 0\ %;-0\ %;0\ %
		displayFolder: 02 Ppto vs Real
		lineageTag: c87924ea-9a2d-40d9-acd1-3f11a6210689

		changedProperty = IsHidden

