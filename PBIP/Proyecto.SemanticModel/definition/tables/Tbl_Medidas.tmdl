	measure 'HTML Demografico Promedio Shell' =
			VAR _colab = IF(ISBLANK([Tot_empleados_Promedio]), "-", FORMAT([Tot_empleados_Promedio], "#,##0"))
			VAR _fem = IF(ISBLANK([%FEM]), "-", FORMAT([%FEM], "0%"))
			VAR _masc = IF(ISBLANK([%MASC]), "-", FORMAT([%MASC], "0%"))
			VAR _edad = IF(ISBLANK([Prom_Edad]), "-", FORMAT([Prom_Edad], "0") & " a&ntilde;os")
			VAR _gen = IF(ISBLANK([Generacion_Top]), "-", [Generacion_Top])
			VAR _antig = IF(ISBLANK([Rango_Antiguedad_Moda]), "-", [Rango_Antiguedad_Moda])
			RETURN
			"<div style='width:2100px;height:900px;box-sizing:border-box;position:relative;background:#F7F9FC;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
