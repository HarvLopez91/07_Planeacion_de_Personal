		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

	measure GL_Ppto_Visual_Otros = IF ( NOT [GL_Usar_Millones], [GL_Ppto_Gasto_Personal], BLANK() )
		formatString: \$\ #,0.###############;-\$\ #,0.###############;\$\ #,0.###############
		displayFolder: 02 Ppto vs Real
		lineageTag: 51be7814-436f-4757-8731-3988c3f8661c

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"es-CO"}

	measure GL_Real_Visual_Otros = IF ( NOT [GL_Usar_Millones], [GL_Gasto_Personal], BLANK() )
		formatString: \$\ #,0.###############;-\$\ #,0.###############;\$\ #,0.###############
		displayFolder: 02 Ppto vs Real
