	measure Prod_Usar_Millones =

			VAR HayFiltroGrupo =
			    ISFILTERED ( Empresas[Grupo Empresa] )
			VAR HayFiltroEmpresa =
			    ISFILTERED ( Empresas[Empresas] )
			VAR GruposSeleccionados =
			    FILTER (
			        ALLSELECTED ( Empresas[Grupo Empresa] ),
			        NOT ISBLANK ( Empresas[Grupo Empresa] )
			    )
			VAR CantidadGruposVisibles =
			    COUNTROWS ( GruposSeleccionados )
			VAR CantidadTotalGrupos =
			    CALCULATE (
			        DISTINCTCOUNT ( Empresas[Grupo Empresa] ),
			        REMOVEFILTERS ( Empresas )
			    )
			VAR GrupoUnico =
			    SELECTEDVALUE ( Empresas[Grupo Empresa] )
			VAR EsChallengerUnico =
			    CantidadGruposVisibles = 1
			        && GrupoUnico = "Challenger"
			VAR EstanTodosLosGrupos =
			    CantidadGruposVisibles = CantidadTotalGrupos
			VAR SinFiltroNegocio =
			    NOT HayFiltroGrupo && NOT HayFiltroEmpresa
			RETURN
			    EsChallengerUnico || EstanTodosLosGrupos || SinFiltroNegocio
		displayFolder: 05 Productividad
		lineageTag: 3db170f4-6e4d-4ac6-a39d-242d1724248c

		changedProperty = IsHidden

	measure Prod_Gasto_Personal_Challenger =

			IF ( [Prod_Usar_Millones], [Prod_Gasto_Personal], BLANK() )
		displayFolder: 05 Productividad
