	measure Tot_empleados_Promedio =
			
			AVERAGEX(
			    VALUES('PLANTA DE PERSONAL'[Mes]),
			    CALCULATE( COUNT('PLANTA DE PERSONAL'[ID]) )
			)
		formatString: 0.00
		displayFolder: 01 HeadCount HC
		lineageTag: 21a53e63-c392-4f68-aeff-f3eb941e720c

	measure Generacion_Top =
			CALCULATE(
			    FIRSTNONBLANK('PLANTA DE PERSONAL'[GENERACIÓN], 1),
			    TOPN(1, VALUES('PLANTA DE PERSONAL'[GENERACIÓN]), [Tot_empleados_Promedio], DESC)
			)
		displayFolder: 01 HeadCount HC - Demografico
		lineageTag: a1b2c3d4-e5f6-7890-a1b2-c3d4e5f67890

	measure Prom_Edad =
			IFERROR(
			    AVERAGEX('PLANTA DE PERSONAL', VALUE('PLANTA DE PERSONAL'[EDAD])),
			    BLANK()
			)
		displayFolder: 01 HeadCount HC - Demografico
		lineageTag: b2c3d4e5-f6a7-8901-b2c3-d4e5f6a78901

	measure Rango_Antiguedad_Moda =
			CALCULATE(
			    FIRSTNONBLANK('PLANTA DE PERSONAL'[Rango Antigüedad], 1),
			    TOPN(1, VALUES('PLANTA DE PERSONAL'[Rango Antigüedad]), [Tot_empleados_Promedio], DESC)
			)
		displayFolder: 01 HeadCount HC - Demografico
		lineageTag: c3d4e5f6-a7b8-9012-c3d4-e5f6a7b89012

	measure HTML_P1_Header =
			"<div style='width:2100px;height:134px;position:relative;background:#F7F9FC;font-family:Outfit,Poppins,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:2100px;height:76px;background:#0B1C35;color:#fff;padding:17px 40px;box-sizing:border-box;display:flex;align-items:center;justify-content:space-between;'>" &
			"<div><div style='font-size:11px;letter-spacing:1.8px;text-transform:uppercase;color:#F7931E;font-weight:800;'>Dashboard Corporativo - Grupo LEMCO</div><div style='font-size:25px;line-height:29px;font-weight:850;margin-top:4px;'>Demogr" & UNICHAR(225) & "fico (Promedio)</div></div>" &
			"<div style='font-size:10px;color:#D8E4F2;text-transform:uppercase;letter-spacing:1.4px;'>Planeaci" & UNICHAR(243) & "n de Personal | People Analytics</div></div>" &
			"<div style='position:absolute;left:40px;top:84px;width:2020px;height:42px;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:14px;box-sizing:border-box;box-shadow:0 10px 28px rgba(11,28,53,.07);overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:7px;height:42px;background:#F7931E;'></div>" &
			"<div style='position:absolute;left:22px;top:9px;width:210px;'><div style='font-size:10px;font-weight:900;color:#0B1C35;text-transform:uppercase;letter-spacing:1px;'>Contexto de an" & UNICHAR(225) & "lisis</div><div style='font-size:8.5px;color:#6B7D93;margin-top:3px;'>Filtros activos para lectura demogr" & UNICHAR(225) & "fica.</div></div>" &
			"<div style='position:absolute;left:260px;top:6px;width:210px;height:30px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:5px 9px;'><div style='font-size:8px;color:#1A3059;font-weight:800;'>A" & UNICHAR(241) & "o</div></div>" &
			"<div style='position:absolute;left:472px;top:6px;width:470px;height:30px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:5px 9px;'><div style='font-size:8px;color:#1A3059;font-weight:800;'>Empresa</div></div>" &
			"<div style='position:absolute;left:944px;top:6px;width:354px;height:30px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:5px 9px;'><div style='font-size:8px;color:#1A3059;font-weight:800;'>Tipo contrato</div></div>" &
			"</div></div>"
		displayFolder: 11 HTML Content
		lineageTag: d4e5f6a7-b8c9-0123-d4e5-f6a7b8c90123

	measure HTML_P1_Footer =
			VAR _fecha = FORMAT(NOW(), "DD/MM/YYYY HH:MM")
			RETURN
			"<div style='width:100%;height:100%;display:flex;align-items:center;justify-content:space-between;padding:0 22px;box-sizing:border-box;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:9px;font-family:Outfit,Poppins,Segoe UI,Arial,sans-serif;'>" &
			"<span style='color:#53657D;font-size:9.5px;letter-spacing:.3px;'>Fuente: PLANTA DE PERSONAL " & UNICHAR(183) & " Promedio mensual " & UNICHAR(183) & " Ultima actualizaci" & UNICHAR(243) & "n: " & _fecha & "</span>" &
			"<span style='color:#F7931E;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;'>Propuesta visual basada en Inicio Corporativo</span></div>"
		displayFolder: 11 HTML Content
		lineageTag: e5f6a7b8-c9d0-1234-e5f6-a7b8c9d01234

	measure HTML_P1_KPIs =
			VAR _colab = FORMAT([Tot_empleados_Promedio], "#,##0")
			VAR _edad = IF(ISBLANK([Prom_Edad]), "-", FORMAT([Prom_Edad], "0") & " a" & UNICHAR(241) & "os")
			VAR _pFem = FORMAT([%FEM], "0%")
			VAR _pMasc = FORMAT([%MASC], "0%")
			VAR _wFem = FORMAT(MIN([%FEM], 1) * 160, "0")
			VAR _wMasc = FORMAT(MIN([%MASC], 1) * 160, "0")
			VAR _antig = IF(ISBLANK([Rango_Antiguedad_Moda]), "-", [Rango_Antiguedad_Moda])
			VAR _gen = IF(ISBLANK([Generacion_Top]), "-", [Generacion_Top])
			VAR _card = "flex:1;background:#F7F9FC;border-radius:8px;padding:13px 15px;display:flex;flex-direction:column;justify-content:space-between;border-left:4px solid "
			VAR _lbl = "color:#53657D;font-size:9px;text-transform:uppercase;letter-spacing:1.2px"
			VAR _val = "color:#1B487F;font-size:26px;font-weight:850;line-height:1"
			RETURN
			"<div style='width:100%;height:100%;box-sizing:border-box;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:14px;box-shadow:0 10px 28px rgba(11,28,53,.07);font-family:Outfit,Poppins,Segoe UI,Arial,sans-serif;display:flex;align-items:stretch;gap:12px;padding:14px 16px;'>" &
			"<div style='width:230px;padding:13px 8px 13px 16px;box-sizing:border-box;border-left:7px solid #F7931E;'><div style='font-size:10px;color:#0B1C35;font-weight:900;text-transform:uppercase;letter-spacing:1px;'>Indicadores clave</div><div style='font-size:9.5px;color:#6B7D93;line-height:13px;margin-top:6px;'>Lectura ejecutiva del promedio demogr" & UNICHAR(225) & "fico filtrado.</div></div>" &
			"<div style='" & _card & "#F7931E;'><span style='" & _lbl & "'>Colaboradores</span><span style='" & _val & "'>" & _colab & "</span><span style='color:#F7931E;font-size:9px;font-weight:700'>Promedio mensual</span></div>" &
			"<div style='" & _card & "#1B487F;'><span style='" & _lbl & "'>Edad Promedio</span><span style='" & _val & "'>" & _edad & "</span><span style='color:#53657D;font-size:9px'>Basado en campo EDAD</span></div>" &
			"<div style='" & _card & "#F7931E;flex:1.35;'><span style='" & _lbl & "'>G" & UNICHAR(233) & "nero</span><svg width='160' height='12' style='margin:8px 0'><rect width='" & _wFem & "' height='12' rx='3' fill='#F7931E'/><rect x='" & _wFem & "' width='" & _wMasc & "' height='12' rx='3' fill='#1B487F'/></svg><div style='display:flex;gap:14px'><span style='color:#F7931E;font-size:10px;font-weight:800'>F " & _pFem & "</span><span style='color:#1B487F;font-size:10px;font-weight:800'>M " & _pMasc & "</span></div></div>" &
			"<div style='" & _card & "#1A3059;'><span style='" & _lbl & "'>Antig" & UNICHAR(252) & "edad</span><span style='color:#1B487F;font-size:17px;font-weight:850;line-height:1.25'>" & _antig & "</span><span style='color:#53657D;font-size:9px'>Rango predominante</span></div>" &
			"<div style='flex:1;background:#0B1C35;color:#fff;border-radius:8px;padding:13px 15px;display:flex;flex-direction:column;justify-content:space-between;'><span style='color:#B8C8DE;font-size:9px;text-transform:uppercase;letter-spacing:1.2px'>Generaci" & UNICHAR(243) & "n</span><span style='color:#FFFFFF;font-size:17px;font-weight:850;line-height:1.25'>" & _gen & "</span><span style='color:#F7931E;font-size:9px;font-weight:700'>Mayor presencia en planta</span></div></div>"
		displayFolder: 11 HTML Content
		lineageTag: f6a7b8c9-d0e1-2345-f6a7-b8c9d0e12345

