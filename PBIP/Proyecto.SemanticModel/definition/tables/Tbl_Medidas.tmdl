	measure Prod_Efic_Otros =

			IF ( NOT [Prod_Usar_Millones], [Efic], BLANK() )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 05 Productividad
		lineageTag: b97c32d2-ec44-4f47-af0b-d450d0d47ad9

		changedProperty = IsHidden

	measure Subtitulo_Productividad_Comparativo_Acumulado =

			VAR HayFiltroMes =
			    ISFILTERED ( Mes[Meses] )
			VAR MesesSeleccionados =
			    FILTER (
			        ADDCOLUMNS (
			            VALUES ( Mes[Meses] ),
			            "__Orden", CALCULATE ( MAX ( Mes[Numero] ) ),
			            "__Abrev", CALCULATE ( MAX ( Mes[Mes Abrev] ) )
			        ),
			        NOT ISBLANK ( Mes[Meses] )
			    )
			VAR CantidadMeses =
			    COUNTROWS ( MesesSeleccionados )
			VAR CantidadTotalMeses =
			    COUNTROWS ( FILTER ( ALL ( Mes ), NOT ISBLANK ( Mes[Meses] ) ) )
			VAR OrdenMinimo =
			    MINX ( MesesSeleccionados, [__Orden] )
			VAR OrdenMaximo =
			    MAXX ( MesesSeleccionados, [__Orden] )
			VAR AbrevMinima =
			    MAXX (
			        FILTER ( MesesSeleccionados, [__Orden] = OrdenMinimo ),
			        [__Abrev]
			    )
			VAR AbrevMaxima =
			    MAXX (
			        FILTER ( MesesSeleccionados, [__Orden] = OrdenMaximo ),
			        [__Abrev]
			    )
			VAR EsRangoContinuo =
			    CantidadMeses = OrdenMaximo - OrdenMinimo + 1
			VAR ListaMeses =
			    CONCATENATEX (
			        MesesSeleccionados,
			        [__Abrev],
			        ", ",
			        [__Orden],
			        ASC
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        NOT HayFiltroMes || CantidadMeses = 0 || CantidadMeses = CantidadTotalMeses,
			            "Comparativo Acumulado Anual",
			        CantidadMeses = 1,
			            "Comparativo Acumulado (" & AbrevMinima & ") Anual",
			        EsRangoContinuo,
			            "Comparativo Acumulado (" & AbrevMinima & "–" & AbrevMaxima & ") Anual",
			        CantidadMeses <= 4,
			            "Comparativo Acumulado (" & ListaMeses & ") Anual",
			        "Comparativo Acumulado (" & CantidadMeses & " meses seleccionados) Anual"
			    )
		displayFolder: 05 Productividad
		lineageTag: 2debe8ed-0a85-441d-b4b7-7ef66f4ef44d

	partition Tbl_Medidas = m
		mode: import
		source =
				let
				    Origen = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Columna1 = _t]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(Origen,{{"Columna1", type text}}),
				    #"Columnas quitadas" = Table.RemoveColumns(#"Tipo cambiado",{"Columna1"})
				in
				    #"Columnas quitadas"

	annotation PBI_ResultType = Table

